namespace Assurant.Elita.BestBuy.Common.ApiInterfaces
{
    /// <summary>
    /// Interface to connect with BestBuy Work Order API via APIM
    /// </summary>
    public interface IBestBuyWorkOrderApi
    {
        internal const string ApiVersionHeaderName = "api-version";
        internal const string ApiVersion = "1.0";

        [Headers($"{ApiVersionHeaderName}: {ApiVersion}", "Content-Type: application/json")]
        [Post("/gw/assurant-integration/api/workorders/clone")]
        Task<ApiResponse<CloneWorkOrderResponse>> CloneWorkOrderAsync(
            [Header("Authorization")] string bearerToken,
            [Body] CloneWorkOrderRequest request);
    }
}
