public interface IBestBuyWorkOrderService
    {
        Task<CloneWorkOrderResponse> CloneWorkOrderAsync(
            CloneWorkOrderRequest request,
            CancellationToken cancellationToken = default);
    }

    public class BestBuyWorkOrderService : IBestBuyWorkOrderService
    {
        private readonly IBestBuyTokenApi _tokenApi;
        private readonly IBestBuyWorkOrderApi _workOrderApi;
        private readonly ILogger<BestBuyWorkOrderService> _logger;
        private readonly string _basicAuthorization;
        private readonly string _scope;

        public BestBuyWorkOrderService(
            IBestBuyTokenApi tokenApi,
            IBestBuyWorkOrderApi workOrderApi,
            ILogger<BestBuyWorkOrderService> logger,
            string basicAuthorization,
            string scope)
        {
            _tokenApi = tokenApi;
            _workOrderApi = workOrderApi;
            _logger = logger;
            _basicAuthorization = basicAuthorization;
            _scope = scope;
        }

        public async Task<CloneWorkOrderResponse> CloneWorkOrderAsync(
            CloneWorkOrderRequest request,
            CancellationToken cancellationToken = default)
        {
            // Step 1 - Get token
            var tokenResponse = await _tokenApi
                .GetTokenAsync(_basicAuthorization, new BestBuyTokenRequest { Scope = _scope })
                .ConfigureAwait(false);

            if (!tokenResponse.IsSuccessStatusCode || tokenResponse.Content is null)
            {
                var error = tokenResponse.Error?.Message ?? tokenResponse.StatusCode.ToString();
                _logger.LogError("Failed to obtain BestBuy token. Status: {Status}, Error: {Error}",
                    tokenResponse.StatusCode, error);
                throw new InvalidOperationException(
                    $"BestBuy token request failed with status {tokenResponse.StatusCode}: {error}");
            }

            var bearerToken = $"Bearer {tokenResponse.Content.AccessToken}";

            // Step 2 - Call Clone Work Order with the token
            var response = await _workOrderApi
                .CloneWorkOrderAsync(bearerToken, request)
                .ConfigureAwait(false);

            if (!response.IsSuccessStatusCode || response.Content is null)
            {
                var error = response.Error?.Message ?? response.StatusCode.ToString();
                _logger.LogError("CloneWorkOrder failed. Status: {Status}, Error: {Error}",
                    response.StatusCode, error);
                throw new InvalidOperationException(
                    $"CloneWorkOrder request failed with status {response.StatusCode}: {error}");
            }

            return response.Content;
        }
    }
