using Assurant.Elita.BestBuy.Common.Models;
using Refit;

namespace Assurant.Elita.BestBuy.Common.ApiInterfaces
{
    /// <summary>
    /// Interface to obtain Bearer tokens from BestBuy STS (Security Token Service)
    /// </summary>
    public interface IBestBuyTokenApi
    {
        [Headers("Content-Type: application/x-www-form-urlencoded")]
        [Post("/v4.0/falcon/token")]
        Task<ApiResponse<BestBuyTokenResponse>> GetTokenAsync(
            [Header("Authorization")] string basicAuthorization,
            [Body(BodySerializationMethod.UrlEncoded)] BestBuyTokenRequest request);
    }
}

