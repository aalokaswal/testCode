
/// <summary>
        /// Registers the BestBuy Work Order pipeline:
        ///   1. IBestBuyTokenApi  – Refit client that calls the BestBuy STS to get a Bearer token.
        ///   2. IBestBuyTokenService – Singleton that fetches/caches the token.
        ///   3. IBestBuyWorkOrderApi – Refit client that calls the Clone Work Order endpoint.
        ///   4. IBestBuyWorkOrderService – Orchestrates 1-3 and is the type you inject into your handlers.
        ///
        /// Usage (identical pattern to BeginClaimAsync):
        ///   var result = await _workOrderService.CloneWorkOrderAsync(request);
        /// </summary>
        public static IServiceCollection AddBestBuyWorkOrderServices(
            this IServiceCollection services)
        {
            // ── Read configuration ────────────────────────────────────────────
            var tokenBaseUrl = Environment.GetEnvironmentVariable("BestBuyTokenUrl")
                ?? throw new InvalidOperationException(
                    "Environment variable 'BestBuyTokenUrl' is not configured.");

            var tokenAuthorization = Environment.GetEnvironmentVariable("BestBuyTokenAuthorization")
                ?? throw new InvalidOperationException(
                    "Environment variable 'BestBuyTokenAuthorization' is not configured.");

            var workOrderBaseUrl = Environment.GetEnvironmentVariable("BestBuyWorkOrderApi")
                ?? throw new InvalidOperationException(
                    "Environment variable 'BestBuyWorkOrderApi' is not configured.");

            // Scope expected by the BestBuy STS (matches the Postman collection variable)
            var tokenScope = Environment.GetEnvironmentVariable("BestBuyTokenScope")
                ?? "apid-ext-cloud:POST:/gw/assurant-integration/**";

            // ── 1. Register the STS token Refit client ────────────────────────
            //    Base URL  →  https://sts-ext-cld.test.bestbuy.com
            //    Endpoint  →  POST /v4.0/falcon/token
            services
                .AddRefitClient<IBestBuyTokenApi>()
                .ConfigureHttpClient(client =>
                {
                    client.BaseAddress = new Uri(tokenBaseUrl);
                });

            // ── 2. Register the token service as a singleton ──────────────────
            //    Singleton so the in-memory token cache is shared across requests.
            services.AddSingleton<IBestBuyTokenService>(sp =>
            {
                var tokenApi = sp.GetRequiredService<IBestBuyTokenApi>();
                var logger = sp.GetRequiredService<
                    Microsoft.Extensions.Logging.ILogger<BestBuyTokenService>>();

                return new BestBuyTokenService(
                    tokenApi,
                    logger,
                    basicAuthorization: tokenAuthorization,
                    scope: tokenScope);
            });

            // ── 3. Register the Work Order Refit client ───────────────────────
            //    Base URL  →  https://apid-ext-cld.test.bestbuy.com
            //    Endpoint  →  POST /gw/assurant-integration/api/workorders/clone
            //
            //    NOTE: The Bearer token is NOT set here on the HttpClient because
            //    it must be refreshed per-request (token expiry).  Instead, the
            //    token is passed as a header parameter inside CloneWorkOrderAsync.
            services
                .AddRefitClient<IBestBuyWorkOrderApi>()
                .ConfigureHttpClient(client =>
                {
                    // Strip the path part – Refit only needs the base host
                    var uri = new Uri(workOrderBaseUrl);
                    client.BaseAddress = new Uri($"{uri.Scheme}://{uri.Host}");
                });

            // ── 4. Register the Work Order service ────────────────────────────
            services.AddScoped<IBestBuyWorkOrderService, BestBuyWorkOrderService>();

            return services;
        }

